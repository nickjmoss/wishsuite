{
  "name": "wishsuite",
  "version": "1.0.0",
  "description": "Wishlist application",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/nickjmoss/wishsuite"
  },
  "scripts": {
    "start": "nodemon --inspect=0.0.0.0:5858 server/index.js & webpack serve --config webpack.dev.js",
    "start:prod": "npx prisma migrate deploy && npx prisma generate && npx pm2-runtime start ecosystem.config.js --env production",
    "localprod": "webpack --config webpack.prod.js && npx pm2-runtime start ecosystem.config.js --env production",
    "build": "webpack --config webpack.prod.js",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:migrate": "npx prisma migrate dev",
    "deploy": "fly deploy"
  },
  "author": "Nick Moss",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^4.9.0",
    "axios": "^1.2.3",
    "connect-redis": "^6.1.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-history-api-fallback": "^2.2.1",
    "express-session": "^1.17.3",
    "file-loader": "^6.2.0",
    "ioredis": "^5.3.0",
    "node-rsa": "^1.1.1",
    "nodemon": "^2.0.20",
    "pm2": "^5.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "6",
    "redis": "^4.6.4",
    "resolve-url-loader": "^5.0.0",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@babel/cli": "^7.20.7",
    "@babel/core": "^7.20.12",
    "@babel/eslint-parser": "^7.19.1",
